# Supabase (get these from https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — never expose in client code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database changes: use Supabase MCP in Cursor (see .cursor/mcp.json)
# Or run SQL in Dashboard → SQL Editor
